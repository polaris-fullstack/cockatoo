<%= content_for :title, t("scaffold.new.title", model: "Application") %>

<div class="container mx-auto px-4 my-8">
  <div class="flex items-center justify-between mb-4">
    <h1 class="h3">
      <%= link_to "Applications", applications_path, class: "text-black dark:text-white" %>
      <span class="text-gray-400 font-light mx-2">\</span>
      <%= t("scaffold.new.title", model: "Application") %>
    </h1>
  </div>

  <div class="flex">
    <div class="mr-8">
      <%= render 'applications/sections/new_sidebar' %>
    </div>
    <div class="flex-1 p-8 bg-white dark:bg-gray-900 dark:border dark:border-gray-700 rounded shadow">
      <%= render "form", application: @application %>
    </div>
  </div>
</div>
