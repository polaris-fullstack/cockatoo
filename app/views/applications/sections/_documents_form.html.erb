<%= form_with(model: @application, url: documents_step1_application_path(@application), method: :patch) do |form| %>
  <%= hidden_field_tag :current_step, :documents %>
  <%= render "error_messages", resource: form.object %>
  <div>
    <h2 class="font-semibold mb-4">Document Uploads</h2>
    <ul class="list-disc list-inside text-gray-600 text-sm mb-4">
      <li>Proof of Identity (e.g., Passport, Driver’s Licence)</li>
      <li>Proof of Income (Payslips, employment contract, or tax returns)</li>
      <li>Bank Statements</li>
      <li>Proof of Assets</li>
      <li>Proof of Liabilities</li>
      <li>Purchase Contract (if buying)</li>
      <li>Rates Notice (if refinancing)</li>
      <li>Rental Income Evidence (if applicable)</li>
      <li>Visa (if not a citizen/permanent resident)</li>
      <li>Other supporting documents</li>
    </ul>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= form.label :identity_document, "Proof of Identity" %>
        <%= form.file_field :identity_document, direct_upload: true, class: "block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none" %>
      </div>
      <div>
        <%= form.label :income_document, "Proof of Income" %>
        <%= form.file_field :income_document, direct_upload: true, class: "block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none" %>
      </div>
      <div>
        <%= form.label :bank_statement, "Bank Statements" %>
        <%= form.file_field :bank_statement, direct_upload: true, class: "block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none" %>
      </div>
      <div>
        <%= form.label :assets_document, "Proof of Assets" %>
        <%= form.file_field :assets_document, direct_upload: true, class: "block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none" %>
      </div>
      <div>
        <%= form.label :liabilities_document, "Proof of Liabilities" %>
        <%= form.file_field :liabilities_document, direct_upload: true, class: "block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none" %>
      </div>
      <div>
        <%= form.label :purchase_contract, "Purchase Contract (if buying)" %>
        <%= form.file_field :purchase_contract, direct_upload: true, class: "block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none" %>
      </div>
      <div>
        <%= form.label :rates_notice, "Rates Notice (if refinancing)" %>
        <%= form.file_field :rates_notice, direct_upload: true, class: "block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none" %>
      </div>
      <div>
        <%= form.label :rental_income, "Rental Income Evidence (if applicable)" %>
        <%= form.file_field :rental_income, direct_upload: true, class: "block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none" %>
      </div>
    </div>
  </div>
  <div class="flex justify-between mt-6">
    <%= button_tag 'Save Draft', name: 'save_draft', value: true, class: "text-white bg-gray-500 hover:bg-gray-600 focus:ring-4 focus:outline-none focus:ring-gray-300 font-medium rounded-lg text-sm px-5 py-2.5" %>
    <button type="submit" name="next" value="true" class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 ml-2">Next</button>
  </div>
<% end %>
