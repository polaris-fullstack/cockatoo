<%
# Define the application steps and their routes
steps = [
  { name: 'Loan Details', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', route: new_loan_details_applications_path, step: :loan_details },
  { name: 'Applicants', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', route: new_applicants_applications_path, step: :applicants },
  { name: 'Properties', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', route: new_properties_applications_path, step: :properties },
  { name: 'Assets', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', route: new_assets_applications_path, step: :assets },
  { name: 'Liabilities', icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z', route: new_liabilities_applications_path, step: :liabilities },
  { name: 'Documents', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', route: new_documents_applications_path, step: :documents },
  { name: 'Declaration', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', route: new_declaration_applications_path, step: :declaration }
]

# Determine current step
current_step = local_assigns[:current_step]
current_step_index = steps.find_index { |s| s[:step] == current_step }
%>

<nav aria-label="Application Steps" class="px-2 py-4 bg-white dark:bg-gray-800 shadow overflow-hidden rounded-lg">
  <div class="mb-4 px-3">
    <h2 class="text-lg font-medium text-gray-900 dark:text-white">New Application</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400">Complete all sections</p>
  </div>
  
  <div class="space-y-1">
    <% steps.each_with_index do |step, index| %>
      <% 
        is_current = (index == current_step_index)
        is_completed = !is_current && index < current_step_index
        is_accessible = index <= current_step_index
        
        status_class = if is_current
                         "bg-blue-50 text-blue-700 dark:bg-blue-900/20 dark:text-blue-200"
                       elsif is_accessible
                         "text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800"
                       else
                         "text-gray-400 dark:text-gray-500 pointer-events-none opacity-50"
                       end
      %>
      
      <% if is_accessible %>
        <%= link_to step[:route], class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{status_class}", aria: { current: is_current ? 'step' : nil } do %>
          <div class="mr-4 flex-shrink-0 flex items-center justify-center h-8 w-8 rounded-full <%= is_current ? 'bg-blue-100 dark:bg-blue-900' : 'bg-gray-100 dark:bg-gray-700' %>">
            <% if is_completed %>
              <svg class="h-5 w-5 text-blue-600 dark:text-blue-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            <% else %>
              <span class="flex-shrink-0 h-5 w-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="<%= is_current ? 'text-blue-600 dark:text-blue-400' : 'text-gray-600 dark:text-gray-400' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= step[:icon] %>" />
                </svg>
              </span>
            <% end %>
          </div>
          <span class="truncate"><%= step[:name] %></span>
          
          <% if is_completed %>
            <span class="ml-auto">
              <svg class="h-5 w-5 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-label="Completed">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </span>
          <% end %>
        <% end %>
      <% else %>
        <div class="group flex items-center px-3 py-2 text-sm font-medium rounded-md <%= status_class %>">
          <div class="mr-4 flex-shrink-0 flex items-center justify-center h-8 w-8 rounded-full bg-gray-100 dark:bg-gray-700 opacity-50">
            <span class="flex-shrink-0 h-5 w-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= step[:icon] %>" />
              </svg>
            </span>
          </div>
          <span class="truncate"><%= step[:name] %></span>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="pt-6 mt-6 border-t border-gray-200 dark:border-gray-700">
    <div class="px-3">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Application Tips</h3>
      <ul class="mt-3 text-sm space-y-3">
        <li class="text-gray-600 dark:text-gray-300 flex items-start">
          <svg class="flex-shrink-0 h-4 w-4 text-green-500 mt-0.5 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          You can save your progress at any time
        </li>
        <li class="text-gray-600 dark:text-gray-300 flex items-start">
          <svg class="flex-shrink-0 h-4 w-4 text-green-500 mt-0.5 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Have your financial documents ready
        </li>
        <li class="text-gray-600 dark:text-gray-300 flex items-start">
          <svg class="flex-shrink-0 h-4 w-4 text-green-500 mt-0.5 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Complete all sections for submission
        </li>
      </ul>
    </div>
  </div>
</nav>
