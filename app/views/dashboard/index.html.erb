<%= content_for :title, "Dashboard" %>

<div class="container mx-auto px-4 my-12">
  <div class="bg-white dark:bg-gray-900 rounded shadow p-8 flex flex-col items-center justify-center">
    <h1 class="text-3xl font-bold mb-4">Welcome to Your Application Dashboard</h1>
    <p class="mb-8 text-gray-600 dark:text-gray-300 text-lg text-center max-w-xl">
      Start a new finance application or continue an existing one. Use the sidebar to navigate through each section of your application.
    </p>
    <%= link_to 'Start Application', new_loan_details_applications_path, class: 'btn btn-primary text-xl px-8 py-4' %>
  </div>
</div>
