<div class="border rounded p-4 mb-4 bg-gray-50" data-nested-record>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :title, "Title", class: "block text-gray-700 mb-2" %>
      <%= f.select :title, ["Mr", "Mrs", "Ms", "Miss", "Other"], {}, class: "w-full border rounded px-3 py-2" %>
    </div>
    <div>
      <%= f.label :surname, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :surname, class: "w-full border rounded px-3 py-2", placeholder: "e.g., Smith" %>
    </div>
    <div>
      <%= f.label :given_names, "Given name(s)", class: "block text-gray-700 mb-2" %>
      <%= f.text_field :given_names, class: "w-full border rounded px-3 py-2", placeholder: "e.g., John Robert" %>
    </div>
    <div>
      <%= f.label :dob, "Date of Birth", class: "block text-gray-700 mb-2" %>
      <%= f.date_field :dob, class: "w-full border rounded px-3 py-2" %>
    </div>
    <div>
      <%= f.label :drivers_licence, "Driver’s Licence Number", class: "block text-gray-700 mb-2" %>
      <%= f.text_field :drivers_licence, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 12345678" %>
    </div>
    <div>
      <%= f.label :licence_state, "State of Issue", class: "block text-gray-700 mb-2" %>
      <%= f.text_field :licence_state, class: "w-full border rounded px-3 py-2", placeholder: "e.g., NSW" %>
    </div>
    <div>
      <%= f.label :marital_status, "Marital Status", class: "block text-gray-700 mb-2" %>
      <%= f.select :marital_status, ["Married", "De facto", "Single", "Other"], {}, class: "w-full border rounded px-3 py-2" %>
    </div>
    <div>
      <%= f.label :dependants, "Number of financial dependants", class: "block text-gray-700 mb-2" %>
      <%= f.number_field :dependants, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 2" %>
    </div>
    <div>
      <%= f.label :email, class: "block text-gray-700 mb-2" %>
      <%= f.email_field :email, class: "w-full border rounded px-3 py-2", placeholder: "e.g., john.smith@email.com" %>
    </div>
    <div>
      <%= f.label :phone, class: "block text-gray-700 mb-2" %>
      <%= f.telephone_field :phone, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 0400 123 456" %>
    </div>
    <div>
      <%= f.label :address, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :address, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 123 Example St, Suburb" %>
    </div>
    <div>
      <%= f.label :address_state, "Address State", class: "block text-gray-700 mb-2" %>
      <%= f.text_field :address_state, class: "w-full border rounded px-3 py-2", placeholder: "e.g., VIC" %>
    </div>
    <div>
      <%= f.label :address_postcode, "Address Postcode", class: "block text-gray-700 mb-2" %>
      <%= f.text_field :address_postcode, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 3000" %>
    </div>
    <div>
      <div class="flex items-center space-x-1" data-controller="popover">
        <%= f.label :income, "Monthly Gross Income (AUD)", class: "block text-gray-700 mb-2" %>
        <span data-action="mouseenter->popover#show mouseleave->popover#hide" class="cursor-pointer text-gray-500 hover:text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        <div data-popover-target="content" class="hidden absolute z-10 w-64 p-3 text-sm font-light text-gray-600 bg-white border border-gray-200 rounded-lg shadow-sm">
          Enter your total gross monthly income before tax from all sources (employment, self-employment, investments, etc.).
        </div>
      </div>
      <%= f.number_field :income, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 5000" %>
    </div>
    <div>
      <div class="flex items-center space-x-1" data-controller="popover">
        <%= f.label :expenses, "Monthly Living Expenses (AUD)", class: "block text-gray-700 mb-2" %>
        <span data-action="mouseenter->popover#show mouseleave->popover#hide" class="cursor-pointer text-gray-500 hover:text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        <div data-popover-target="content" class="hidden absolute z-10 w-64 p-3 text-sm font-light text-gray-600 bg-white border border-gray-200 rounded-lg shadow-sm">
          Estimate your total monthly living costs, including rent/mortgage payments (if not refinancing), food, utilities, transport, insurance, entertainment, etc.
        </div>
      </div>
      <%= f.number_field :expenses, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 3000" %>
    </div>
    <div>
      <%= f.label :residency_status, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :residency_status, class: "w-full border rounded px-3 py-2", placeholder: "e.g., Permanent Resident" %>
    </div>
    <div>
      <%= f.label :us_citizen, "Are you a U.S. citizen or U.S. resident for tax purposes?", class: "block text-gray-700 mb-2" %>
      <%= f.check_box :us_citizen %>
    </div>
    <div>
      <%= f.label :tin, "Taxpayer Identification Number (TIN)", class: "block text-gray-700 mb-2" %>
      <%= f.text_field :tin, class: "w-full border rounded px-3 py-2" %>
    </div>
    <div>
      <%= f.label :other_tax_countries, "Other tax countries", class: "block text-gray-700 mb-2" %>
      <%= f.text_field :other_tax_countries, class: "w-full border rounded px-3 py-2" %>
    </div>
  </div>
</div>
