<div class="border rounded p-4 mb-4 bg-gray-50">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :employer_name, "Employer's Name", class: "block text-gray-700 mb-2" %>
      <%= f.text_field :employer_name, class: "w-full border rounded px-3 py-2", placeholder: "e.g., Acme Pty Ltd" %>
    </div>
    <div>
      <%= f.label :address, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :address, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 100 Main St, Sydney" %>
    </div>
    <div>
      <%= f.label :state, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :state, class: "w-full border rounded px-3 py-2", placeholder: "e.g., NSW" %>
    </div>
    <div>
      <%= f.label :postcode, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :postcode, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 2000" %>
    </div>
    <div>
      <%= f.label :phone, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :phone, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 02 1234 5678" %>
    </div>
    <div>
      <%= f.label :occupation, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :occupation, class: "w-full border rounded px-3 py-2", placeholder: "e.g., Software Engineer" %>
    </div>
    <div>
      <%= f.label :start_date, class: "block text-gray-700 mb-2" %>
      <%= f.date_field :start_date, class: "w-full border rounded px-3 py-2", placeholder: "Start date" %>
    </div>
    <div>
      <%= f.label :end_date, class: "block text-gray-700 mb-2" %>
      <%= f.date_field :end_date, class: "w-full border rounded px-3 py-2", placeholder: "End date (if applicable)" %>
    </div>
    <div>
      <%= f.label :employment_type, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :employment_type, class: "w-full border rounded px-3 py-2", placeholder: "e.g., Full-time" %>
    </div>
    <div>
      <%= f.label :accountant_name, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :accountant_name, class: "w-full border rounded px-3 py-2", placeholder: "e.g., Jane Accountant" %>
    </div>
    <div>
      <%= f.label :accountant_firm, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :accountant_firm, class: "w-full border rounded px-3 py-2", placeholder: "e.g., Numbers & Co." %>
    </div>
    <div>
      <%= f.label :accountant_phone, class: "block text-gray-700 mb-2" %>
      <%= f.text_field :accountant_phone, class: "w-full border rounded px-3 py-2", placeholder: "e.g., 03 9876 5432" %>
    </div>
  </div>
  <button type="button" class="btn btn-danger mt-2" data-action="click->finance-application-form#removeNested" data-target="employment-history">Remove Employment</button>
</div>
