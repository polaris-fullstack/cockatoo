<%= content_for :title, "Employment Histories" %>
<%= turbo_stream_from :employment_histories %>

<div class="container px-4 mx-auto my-8">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="h3">Employment Histories</h1>

      <div class="text-sm font-medium">
        <span class="text-gray-500 dark:text-gray-300/75">Sort by:</span>
        <%= sortable @employment_histories, :applicant_id, "Applicant", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :employer_name, "Employer name", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :address, "Address", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :state, "State", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :postcode, "Postcode", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :phone, "Phone", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :occupation, "Occupation", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :start_date, "Start date", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :end_date, "End date", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :employment_type, "Employment type", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :accountant_name, "Accountant name", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :accountant_firm, "Accountant firm", class: "text-gray-700 dark:text-gray-300 mr-1" %>
        <%= sortable @employment_histories, :accountant_phone, "Accountant phone", class: "text-gray-700 dark:text-gray-300 mr-1" %>
      </div>
    </div>

    <%= link_to t("scaffold.new.title", model: "Employment History"), new_employment_history_path, class: "btn btn-secondary" %>
  </div>

  <%= tag.div id: ("employment_histories" if first_page?), class: "bg-white dark:bg-gray-900 dark:border dark:border-gray-700 rounded-md shadow p-6 space-y-8" do %>
    <%= render partial: "employment_histories/employment_history", collection: @employment_histories, as: :employment_history, cached: true %>

    <div class="hidden only:block text-center">
      <p class="mb-4 h3">Create your first Employment History</p>
      <%= link_to t("scaffold.new.title", model: "Employment History"), new_employment_history_path, class: "btn btn-primary" %>
    </div>
  <% end %>

  <% if @pagy.pages > 1 %>
    <div class="my-6 text-center">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
