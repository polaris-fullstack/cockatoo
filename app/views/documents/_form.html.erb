<%= form_with(model: document) do |form| %>
  <%= render "error_messages", resource: form.object %>

  <div class="form-group">
    <%= form.label :applicant_id %>
    <%= form.text_field :applicant_id, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :document_type %>
    <%= form.text_field :document_type, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :file %>
    <%= form.text_field :file, class: "form-control" %>
  </div>

  <div>
    <%= form.button button_text(form.send(:submit_default_value)), class: "btn btn-primary" %>

    <% if form.object.new_record? %>
      <%= link_to t("cancel"), documents_path, class: "btn btn-secondary" %>
    <% else %>
      <%= link_to t("cancel"), document_path(@document), class: "btn btn-secondary" %>
    <% end %>
  </div>
<% end %>
